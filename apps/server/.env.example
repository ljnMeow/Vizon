# PostgreSQL 连接信息（把这个文件复制成 .env，并填上你的真实配置）
#
# 例子：
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432
# POSTGRES_DB=vizon
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
#
# Django 会在启动时读取这些环境变量；
# 本项目**强制使用 PostgreSQL**，未配置/配置错误会直接报错（不会回落 sqlite）。
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=Vizon
POSTGRES_USER=postgres
POSTGRES_PASSWORD=linjinnan

# 固定本地开发端口（可选）
# - 如果不设置，`pnpm dev:server` 会自动找一个空闲端口
PORT=8001

# 开发/初始化阶段开关（全局）：
# - 设为 1 会放开所有 DRF API 的默认鉴权，方便你用接口往数据库灌数据
# - 注意：`OPEN_API_AUTH` 现在是 **必须显式配置** 的（不配置会直接启动失败）
OPEN_API_AUTH=0

# Redis（用于 refresh token 会话管理 / 退出登录）
# 例子：
# - 无密码：redis://127.0.0.1:6379/0
# - 有密码（requirepass）：redis://:YOUR_PASSWORD@127.0.0.1:6379/0
# - ACL（用户名+密码）：redis://YOUR_USER:YOUR_PASSWORD@127.0.0.1:6379/0
REDIS_URL=redis://127.0.0.1:6379/0

# token 过期时间（单位：秒）
# - access_token：建议较短（例如 2 分钟=120）
# - refresh_token：建议更长（例如 5 分钟=300）
ACCESS_TOKEN_EXPIRES_SECONDS=120
REFRESH_TOKEN_EXPIRES_SECONDS=300

